# ============================================================
# Σ.Match / KOL Lens 通用环境变量模板
# 可复制为 .env 或 .env.production
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=sigma_match
POSTGRES_USER=sigma
POSTGRES_PASSWORD=sigma_secret_2026
POSTGRES_HOST=your-rds-pg-host
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
POSTGRES_CONNECT_TIMEOUT=5
POSTGRES_APPLICATION_NAME=kol_lens

# --- Redis ---
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=sigma_redis_2026
REDIS_DB=0
REDIS_SSL=0
REDIS_SSL_CERT_REQS=required
REDIS_SOCKET_TIMEOUT=5

# --- DashVector ---
DASHVECTOR_API_KEY=
DASHVECTOR_ENDPOINT=
DASHVECTOR_COLLECTION=influencer_vectors

# --- Embedding 维度 ---
EMBEDDING_DIM=1024

# --- OpenAI / 兼容网关 ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

KOL_LENS_INTENT_MODEL=qwen3.6-plus-2026-04-02
KOL_LENS_INTENT_API_KEY=
KOL_LENS_INTENT_BASE_URL=

KOL_LENS_EMBEDDING_MODEL=qwen3-vl-embedding
KOL_LENS_EMBEDDING_API_KEY=
KOL_LENS_EMBEDDING_BASE_URL=

KOL_LENS_DISABLE_LLM=0

# --- PGY 搜索/扩库 ---
PGY_BLOGGER_SEARCH_URL=https://pgy.xiaohongshu.com/api/solar/cooperator/blogger/v2
PGY_BRAND_USER_ID=6438f862000000000e01e59a
PGY_TRACE_ID=
PGY_AUTHORIZATION=
PGY_COOKIE=
PGY_COOKIE_HEADER=
PGY_COOKIE_HEADERS=
PGY_COOKIE_FILE=data/token.txt

# --- PGY OSS token 下载（兼容用户现有 bug.py 流程） ---
PGY_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
PGY_OSS_BUCKET=redmagic
PGY_OSS_OBJECT_KEY=KOL/token.txt
PGY_OSS_ACCESS_KEY_ID=
PGY_OSS_ACCESS_KEY_SECRET=

# --- 达人补充数据视觉识别 ---
CREATOR_DATA_VL_MODEL=qwen-vl-max-2025-01-25
CREATOR_DATA_VL_API_KEY=
CREATOR_DATA_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# KOL Lens Windows 本地部署配置
# 优先复制本文件使用；app.py 会自动加载 .env.production
# ============================================================

# --- PostgreSQL / Aliyun RDS ---
POSTGRES_DB=sigma_match
POSTGRES_USER=sigma
POSTGRES_PASSWORD=sigma_secret_2026
POSTGRES_HOST=your-rds-pg-host
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
POSTGRES_CONNECT_TIMEOUT=5
POSTGRES_APPLICATION_NAME=kol_lens

# --- Redis / Aliyun Tair or Redis ---
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=sigma_redis_2026
REDIS_DB=0
REDIS_SSL=0
REDIS_SSL_CERT_REQS=required
REDIS_SOCKET_TIMEOUT=5

# --- DashVector ---
DASHVECTOR_API_KEY=
DASHVECTOR_ENDPOINT=
DASHVECTOR_COLLECTION=influencer_vectors
EMBEDDING_DIM=1024

# --- OpenAI / 兼容网关 ---
# 用于核心意图解析与文本嵌入；如果你使用官方 OpenAI，这里只填 OPENAI_API_KEY 即可
OPENAI_API_KEY=请替换为真实值
OPENAI_BASE_URL=

KOL_LENS_INTENT_MODEL=gpt-4.1-mini
KOL_LENS_INTENT_API_KEY=
KOL_LENS_INTENT_BASE_URL=

KOL_LENS_EMBEDDING_MODEL=text-embedding-3-small
KOL_LENS_EMBEDDING_API_KEY=
KOL_LENS_EMBEDDING_BASE_URL=

# 设为 1 时，意图解析会优先走规则回退，降低对在线模型的依赖
KOL_LENS_DISABLE_LLM=0

# --- PGY 搜索/扩库 ---
# 以下两个默认值已内置在代码里，这里保留只是为了显式可见
PGY_BLOGGER_SEARCH_URL=https://pgy.xiaohongshu.com/api/solar/cooperator/blogger/v2
PGY_BRAND_USER_ID=6438f862000000000e01e59a
PGY_TRACE_ID=

# 如果你已有可直接使用的请求头，可填这里
PGY_AUTHORIZATION=
PGY_COOKIE=
PGY_COOKIE_HEADER=

# 如果你有多条 Cookie，可逐行粘贴
PGY_COOKIE_HEADERS=

# 默认支持直接读取 backend/data/token.txt 对应的项目内路径；从 backend 目录启动时填写 data/token.txt 即可
PGY_COOKIE_FILE=data/token.txt

# 兼容你的 bug.py：支持从 OSS 自动下载 token.txt
PGY_OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
PGY_OSS_BUCKET=redmagic
PGY_OSS_OBJECT_KEY=KOL/token.txt
PGY_OSS_ACCESS_KEY_ID=
PGY_OSS_ACCESS_KEY_SECRET=

# --- 达人补充数据视觉识别 ---
# 默认改成更贴近你 bug.py 的视觉识别流程：Qwen-VL + 兼容 OpenAI 接口
CREATOR_DATA_VL_MODEL=qwen-vl-max-2025-01-25
CREATOR_DATA_VL_API_KEY=
CREATOR_DATA_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
